{
  "name": "@ecoroute/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for EcoRoute - Carbon-Aware Routing",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc"
  },
  "keywords": [
    "routing",
    "sustainability",
    "carbon-aware",
    "green-tech",
    "maps"
  ],
  "author": "EcoRoute Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsup": "^8.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3"
  }
}
